# Anthropic Claude API Key
# https://console.anthropic.com でAPIキーを取得
ANTHROPIC_API_KEY=sk-ant-

# サーバーポート（デフォルト: 3000）
PORT=3000

# 外部公開アドレス（IPまたはドメイン）。起動時にコンソールへ表示される
# 例: 192.168.1.10, example.com
# HOST=192.168.1.10

# 使用するClaudeモデル（デフォルト: claude-sonnet-4-6）
# 例: claude-opus-4-6, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# セッションシークレット（任意の文字列）
SESSION_SECRET=your-secret-key-here
