{
  "name": "ai-trpg-web",
  "version": "1.0.0",
  "description": "Web-based AI TRPG with vertical text novel display",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "esbuild public/js/app.ts --bundle --outfile=public/js/dist/app.js --target=es2020 --format=esm --sourcemap",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "watch:frontend": "esbuild public/js/app.ts --bundle --outfile=public/js/dist/app.js --target=es2020 --format=esm --sourcemap --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "chromadb": "^3.4.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
